        "prettier": "^3.0.0",
        "turbo": "^2.0.0",
        "typescript": "^5.0.0"
    },
    "overrides": {
        "react": "19.2.7",
        "react-dom": "19.2.7"
    },
    "packageManager": "npm@10.0.0",
    "dependencies": {
        "@fontsource/nunito": "^5.2.7"
    }
